<view class="mp-card flush" style="display:flex;gap:4px;padding:10px 12px">
  <view class="scan-mode {{status === '' ? 'active' : ''}}" bindtap="filter" data-status="">全部</view>
  <view class="scan-mode {{status === '待支付' ? 'active' : ''}}" bindtap="filter" data-status="待支付">待支付</view>
  <view class="scan-mode {{status === '已支付' ? 'active' : ''}}" bindtap="filter" data-status="已支付">已支付</view>
  <view class="scan-mode {{status === '已核销' ? 'active' : ''}}" bindtap="filter" data-status="已核销">已核销</view>
</view>

<view class="mp-record-list" style="margin-top:12px">
  <view class="mp-record-row" wx:for="{{orders}}" wx:key="id">
    <view class="rr-icon">📄</view>
    <view class="rr-info">
      <view class="rr-title">{{item.order_no}}</view>
      <view class="rr-sub">{{item.created_at}} · {{item.payment_method || '微信'}}</view>
      <view class="rr-sub">{{item.user?.nickname || '顾客'}}</view>
    </view>
    <view style="text-align:right">
      <view class="rr-amount">¥{{item.amount}}</view>
      <text class="tag {{item.status === '已支付' ? 'tag-success' : ''}}">{{item.status}}</text>
    </view>
  </view>
</view>
<view wx:if="{{!orders.length}}" class="empty">暂无订单</view>
