<view class="me-header">
  <view class="me-avatar">🏪</view>
  <view style="flex:1">
    <view class="me-name">{{shopName}}</view>
    <view class="me-role">商户管理员</view>
  </view>
</view>

<view class="me-assets">
  <view class="me-asset"><view class="val">¥{{balance}}</view><view class="lbl">账户余额</view></view>
  <view class="me-asset"><view class="val">{{orderCount}}</view><view class="lbl">今日订单</view></view>
  <view class="me-asset"><view class="val">{{verifyCount}}</view><view class="lbl">今日核销</view></view>
</view>

<view class="mp-menu-row" bindtap="goMenu"><view class="mm-icon">🏪</view>菜单/商品管理<view class="mm-extra">上架管理</view><view class="mm-arrow">›</view></view>
<view class="mp-menu-row" bindtap="goBusiness"><view class="mm-icon">📊</view>经营数据清单<view class="mm-arrow">›</view></view>
<view class="mp-menu-row" bindtap="goWithdrawAccount"><view class="mm-icon">💳</view>提现账户<view class="mm-arrow">›</view></view>
<view class="mp-menu-row" bindtap="logout"><view class="mm-icon">🚪</view>退出登录<view class="mm-arrow">›</view></view>
