<view style="background:linear-gradient(180deg,#f6ffed 0%,#fff 100%);padding:16px">
  <view style="display:flex;align-items:center;justify-content:space-between">
    <view style="font-size:20px;font-weight:700">🌾 袁夫稻田</view>
    <view style="font-size:13px;color:rgba(0,0,0,0.45)">{{userName || '探索自然'}}</view>
  </view>
</view>

<view class="mp-card flush" style="background:linear-gradient(135deg,#1677ff,#0958d9);color:#fff;text-align:center;padding:20px">
  <view style="font-size:15px;opacity:0.85">扫码点餐 · 会员码</view>
  <view style="font-size:28px;font-weight:700;margin:8px 0">¥{{user.balance || '0.00'}}</view>
  <view style="font-size:12px;opacity:0.75">可用余额</view>
  <button class="mp-btn primary" style="background:rgba(255,255,255,0.2);color:#fff;margin-top:12px" bindtap="goMemberQr">亮码支付</button>
</view>

<view class="mp-section-title">商品分类</view>
<view style="display:flex;flex-wrap:wrap;padding:0 12px;gap:8px">
  <view wx:for="{{categories}}" wx:key="id" class="qa-item" bindtap="goCategory" data-id="{{item.id}}">
    <view class="qa-icon" style="background:{{item.color}}">{{item.icon}}</view>
    <text style="white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:80px">{{item.name}}</text>
  </view>
</view>

<view class="mp-section-title">新品专区</view>
<scroll-view scroll-x style="white-space:nowrap;padding:0 12px">
  <view wx:for="{{newProducts}}" wx:key="id" style="display:inline-block;width:150px;margin-right:10px" bindtap="goProduct" data-id="{{item.id}}">
    <view style="height:120px;background:#f5f5f5;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:40px">🍽</view>
    <view style="font-size:14px;margin-top:8px">{{item.name}}</view>
    <view style="color:#ff4d4f;font-weight:600">¥{{item.price}}</view>
  </view>
</scroll-view>

<view class="mp-section-title">热门推荐</view>
<view wx:for="{{hotProducts}}" wx:key="id" class="mp-card flush" style="display:flex;gap:10px" bindtap="goProduct" data-id="{{item.id}}">
  <view style="width:80px;height:80px;background:#f5f5f5;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:32px;flex-shrink:0">🍽</view>
  <view style="flex:1;min-width:0">
    <view style="font-size:15px;font-weight:500">{{item.name}}</view>
    <view style="font-size:12px;color:rgba(0,0,0,0.45);margin:4px 0">{{item.desc}}</view>
    <view style="color:#ff4d4f;font-weight:600">¥{{item.price}}</view>
  </view>
</view>
