<view class="mp-card flush" style="text-align:center;padding:24px 16px">
  <view style="font-size:13px;color:rgba(0,0,0,0.45)">当前余额</view>
  <view style="font-size:40px;font-weight:700;color:#1677ff;margin:8px 0">¥{{user.balance || '0.00'}}</view>
</view>

<view class="mp-section-title">选择充值金额</view>
<view style="display:flex;flex-wrap:wrap;gap:10px;padding:0 12px">
  <view wx:for="{{tiers}}" wx:key="amount" bindtap="selectTier" data-amount="{{item.amount}}" data-bonus="{{item.bonus}}"
    class="mp-card flush" style="flex:1 1 40%;text-align:center;min-width:140px;padding:16px;border:2px solid {{selectedAmount === item.amount ? '#1677ff' : 'transparent'}}">
    <view style="font-size:22px;font-weight:600">¥{{item.amount}}</view>
    <view style="font-size:12px;color:#52c41a;margin-top:4px" wx:if="{{item.bonus > 0}}">送 ¥{{item.bonus}}</view>
    <view style="font-size:13px;color:rgba(0,0,0,0.45);margin-top:2px">到账 ¥{{item.amount + item.bonus}}</view>
  </view>
</view>

<view style="padding:16px">
  <button class="mp-btn primary block" style="height:48px;font-size:16px" bindtap="doRecharge">确认充值 ¥{{selectedAmount + (selectedBonus || 0)}}</button>
</view>
