<view wx:for="{{items}}" wx:key="id" class="mp-card flush" style="display:flex;align-items:center;gap:10px">
  <checkbox checked="{{item.selected}}" bindtap="toggleSelect" data-id="{{item.id}}" />
  <view style="width:60px;height:60px;background:#f5f5f5;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:24px">🍽</view>
  <view style="flex:1">
    <view style="font-size:15px;font-weight:500">{{item.name}}</view>
    <view style="color:#ff4d4f;font-weight:600;margin-top:4px">¥{{item.price}}</view>
  </view>
  <view style="display:flex;align-items:center;gap:6px">
    <view bindtap="decQty" data-id="{{item.id}}" style="width:28px;height:28px;border-radius:50%;border:1px solid #d9d9d9;display:flex;align-items:center;justify-content:center;font-size:16px">-</view>
    <text style="min-width:24px;text-align:center">{{item.qty}}</text>
    <view bindtap="incQty" data-id="{{item.id}}" style="width:28px;height:28px;border-radius:50%;background:#1677ff;color:#fff;display:flex;align-items:center;justify-content:center;font-size:16px">+</view>
  </view>
</view>

<view wx:if="{{items.length === 0}}" class="empty">
  <view style="font-size:48px;opacity:0.3;margin-bottom:12px">🛒</view>
  <view>购物车是空的</view>
</view>

<view wx:if="{{items.length > 0}}" style="position:fixed;bottom:0;left:0;right:0;background:#fff;border-top:1px solid #f0f0f0;padding:12px 16px;display:flex;align-items:center;gap:10px;z-index:10">
  <checkbox checked="{{allSelected}}" bindtap="toggleAll" /> 全选
  <view style="flex:1;text-align:right">
    <view style="font-size:13px;color:rgba(0,0,0,0.45)">合计</view>
    <view style="color:#ff4d4f;font-size:20px;font-weight:600">¥{{totalPrice}}</view>
  </view>
  <button class="mp-btn primary" style="height:40px;font-size:15px;padding:0 24px" bindtap="goCheckout">结算({{selectedCount}})</button>
</view>
