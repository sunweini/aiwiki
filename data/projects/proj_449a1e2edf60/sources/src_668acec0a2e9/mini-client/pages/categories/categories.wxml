<view style="display:flex;height:100vh">
  <scroll-view scroll-y style="width:100px;background:#f5f5f5">
    <view wx:for="{{categories}}" wx:key="id" class="cat-nav {{currentId === item.id ? 'active' : ''}}" bindtap="selectCat" data-id="{{item.id}}">{{item.name}}</view>
  </scroll-view>
  <scroll-view scroll-y style="flex:1;padding:8px">
    <view wx:for="{{products}}" wx:key="id" class="mp-card flush" style="display:flex;gap:10px;margin:0 0 8px" bindtap="goProduct" data-id="{{item.id}}">
      <view style="width:70px;height:70px;background:#f5f5f5;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:28px;flex-shrink:0">🍽</view>
      <view style="flex:1;min-width:0">
        <view style="font-size:14px;font-weight:500">{{item.name}}</view>
        <view style="font-size:12px;color:rgba(0,0,0,0.45);margin:4px 0">{{item.desc}}</view>
        <view style="color:#ff4d4f;font-weight:600">¥{{item.price}}</view>
      </view>
    </view>
  </scroll-view>
</view>
