<view style="background:linear-gradient(135deg,#1677ff,#0958d9);color:#fff;padding:24px 16px">
  <view style="display:flex;align-items:center;gap:14px">
    <view style="width:54px;height:54px;border-radius:50%;background:rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:600">{{avatarText}}</view>
    <view>
      <view style="font-size:18px;font-weight:600">{{user.nickname || '稻田守望者'}}</view>
      <view style="font-size:13px;opacity:0.8;margin-top:2px">{{user.phone || '未绑定手机'}}</view>
    </view>
  </view>
  <view style="display:flex;justify-content:space-around;margin-top:16px">
    <view style="text-align:center" bindtap="goRecharge">
      <view style="font-size:22px;font-weight:700">¥{{user.balance || '0.00'}}</view>
      <view style="font-size:11px;opacity:0.75">余额</view>
    </view>
    <view style="text-align:center" bindtap="goOrders">
      <view style="font-size:22px;font-weight:700">{{user.total_purchases || 0}}</view>
      <view style="font-size:11px;opacity:0.75">购买</view>
    </view>
    <view style="text-align:center" bindtap="goPoints">
      <view style="font-size:22px;font-weight:700">{{user.points || 0}}</view>
      <view style="font-size:11px;opacity:0.75">积分</view>
    </view>
  </view>
</view>

<view class="mp-section-title">我的订单</view>
<view class="mp-card flush">
  <view class="me-row" bindtap="goOrders"><view style="font-size:16px">📋</view><view style="flex:1">全部订单</view><view style="color:rgba(0,0,0,0.45)">›</view></view>
  <view class="me-row" bindtap="goMemberQr"><view style="font-size:16px">⬛</view><view style="flex:1">亮码支付</view><view style="color:rgba(0,0,0,0.45)">›</view></view>
</view>

<view class="mp-section-title">功能</view>
<view class="mp-card flush">
  <view class="me-row" bindtap="goRecharge"><view style="font-size:16px">💰</view><view style="flex:1">余额充值</view><view style="color:rgba(0,0,0,0.45)">›</view></view>
  <view class="me-row" bindtap="goActivities"><view style="font-size:16px">🎉</view><view style="flex:1">园区活动</view><view style="color:rgba(0,0,0,0.45)">›</view></view>
  <view class="me-row" bindtap="goGate"><view style="font-size:16px">🚪</view><view style="flex:1">闸机通行</view><view style="color:rgba(0,0,0,0.45)">›</view></view>
  <view class="me-row" bindtap="showAbout"><view style="font-size:16px">ℹ</view><view style="flex:1">关于我们</view><view style="color:rgba(0,0,0,0.45)">v2.0</view></view>
</view>

<view style="text-align:center;padding:30px 0">
  <view class="mp-btn gray" style="margin:0 auto" bindtap="logout">退出登录</view>
</view>
