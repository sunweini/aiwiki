<view wx:for="{{activities}}" wx:key="id" class="mp-card flush" bindtap="viewDetail" data-id="{{item.id}}">
  <view style="height:150px;background:#f5f5f5;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:48px">🎉</view>
  <view style="margin-top:10px">
    <view style="font-size:16px;font-weight:500">{{item.title}}</view>
    <view style="font-size:12px;color:rgba(0,0,0,0.45);margin-top:4px">{{item.start_at}} ~ {{item.end_at}}</view>
    <view class="tag warning" style="margin-top:6px">{{item.type}}</view>
  </view>
</view>
<view wx:if="{{activities.length === 0}}" class="empty">
  <view style="font-size:48px;opacity:0.3;margin-bottom:12px">🎉</view>
  <view>暂无活动</view>
</view>
