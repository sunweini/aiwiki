<view class="mp-card flush" style="text-align:center;padding:40px 20px">
  <view style="font-size:64px;margin-bottom:16px">🚪</view>
  <view style="font-size:16px;font-weight:500;margin-bottom:8px">闸机通行</view>
  <view style="font-size:13px;color:rgba(0,0,0,0.45);margin-bottom:24px">扫码或刷脸通行</view>
  <view style="display:flex;gap:10px">
    <view class="mp-btn primary" style="flex:1" bindtap="scanCode">📷 扫码通行</view>
    <view class="mp-btn" style="flex:1;background:#f5f5f5;color:rgba(0,0,0,0.65)" bindtap="faceEntry">👤 人脸通行</view>
  </view>
</view>

<view class="mp-card flush">
  <view style="font-size:15px;font-weight:500;margin-bottom:8px">通行记录</view>
  <view wx:for="{{records}}" wx:key="id" class="mp-record-row" style="padding:10px 0;border-bottom:1px solid #f5f5f5">
    <view class="rr-info"><view class="rr-title">{{item.gate_name}}</view><view class="rr-sub">{{item.entry_time}} · {{item.direction}}</view></view>
    <view class="tag {{item.verify_method === '人脸' ? 'success' : ''}}">{{item.verify_method}}</view>
  </view>
</view>
