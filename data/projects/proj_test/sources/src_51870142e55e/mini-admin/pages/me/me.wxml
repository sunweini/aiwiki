<view class="mp-data-hero" style="padding:24px 16px">
  <view style="display:flex;align-items:center;gap:14px">
    <view style="width:54px;height:54px;border-radius:50%;background:linear-gradient(135deg,#4096ff,#1677ff);color:#fff;display:flex;align-items:center;justify-content:center;font-size:22px;font-weight:600">{{avatarText}}</view>
    <view>
      <view style="font-size:18px;font-weight:600">{{employee.real_name || '管理员'}}</view>
      <view style="font-size:13px;opacity:0.8;margin-top:2px">{{employee.role || '园区管理员'}}</view>
    </view>
  </view>
</view>

<view class="mp-section-title">功能</view>
<view class="mp-card flush">
  <view class="me-row" bindtap="switchPark">
    <view style="font-size:16px">⇄</view>
    <view style="flex:1">切换园区</view>
    <view style="color:rgba(0,0,0,0.45);font-size:13px">{{parkName}}</view>
  </view>
  <view class="me-row" bindtap="showInfo">
    <view style="font-size:16px">ℹ</view>
    <view style="flex:1">园区信息</view>
    <view style="color:rgba(0,0,0,0.45)">›</view>
  </view>
  <view class="me-row" bindtap="showAbout">
    <view style="font-size:16px">⚙</view>
    <view style="flex:1">关于</view>
    <view style="color:rgba(0,0,0,0.45);font-size:13px">v2.0</view>
  </view>
</view>

<view style="text-align:center;padding:40px 0">
  <view class="mp-btn gray" style="margin:0 auto" bindtap="logout">退出登录</view>
</view>
