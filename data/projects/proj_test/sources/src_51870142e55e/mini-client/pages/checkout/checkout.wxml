<view class="mp-card flush">
  <view class="me-row" bindtap="selectAddress"><view style="font-size:20px">📍</view><view style="flex:1"><view style="font-size:15px;font-weight:500">{{address || '选择用餐地址'}}</view><view style="font-size:12px;color:rgba(0,0,0,0.45);margin-top:2px">选择园区和用餐时间</view></view><view style="color:rgba(0,0,0,0.45)">›</view></view>
</view>

<view class="mp-card flush">
  <view style="font-size:15px;font-weight:500;margin-bottom:12px">订单商品</view>
  <view wx:for="{{items}}" wx:key="id" style="display:flex;justify-content:space-between;padding:8px 0">
    <view style="flex:1;font-size:14px">{{item.name}} x{{item.qty}}</view>
    <view style="color:#ff4d4f;font-weight:500">¥{{(item.price * item.qty).toFixed(2)}}</view>
  </view>
  <view style="border-top:1px solid #f5f5f5;margin-top:8px;padding-top:8px;display:flex;justify-content:space-between">
    <view style="font-size:15px;font-weight:500">合计</view>
    <view style="color:#ff4d4f;font-size:18px;font-weight:600">¥{{totalPrice}}</view>
  </view>
</view>

<view class="mp-card flush">
  <view class="form-item"><view class="form-label">备注</view><textarea class="form-input" style="height:60px;padding:8px 12px" placeholder="特殊要求（可选）" bindinput="setRemark" /></view>
</view>

<view style="position:fixed;bottom:0;left:0;right:0;background:#fff;border-top:1px solid #f0f0f0;padding:12px 16px;display:flex;align-items:center;gap:10px;z-index:10">
  <view style="flex:1">
    <view style="font-size:13px;color:rgba(0,0,0,0.45)">合计</view>
    <view style="color:#ff4d4f;font-size:22px;font-weight:600">¥{{totalPrice}}</view>
  </view>
  <button class="mp-btn primary" style="height:44px;font-size:16px;padding:0 32px" bindtap="submitOrder">提交订单</button>
</view>
