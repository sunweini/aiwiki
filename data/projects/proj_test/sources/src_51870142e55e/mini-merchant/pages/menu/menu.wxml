<view class="mp-section-title" style="margin-top:8px">商品管理</view>
<view wx:for="{{products}}" wx:key="id" class="mp-record-row">
  <view class="rr-icon">🍽</view>
  <view class="rr-info">
    <view class="rr-title">{{item.name}}</view>
    <view class="rr-sub">¥{{item.price}} · {{item.status === 1 ? '上架中' : '已下架'}}</view>
  </view>
  <switch checked="{{item.status === 1}}" bindchange="toggleProduct" data-id="{{item.id}}" color="#1677ff"/>
</view>
<view wx:if="{{!products.length}}" class="empty">暂无商品，请前往PC端管理</view>
