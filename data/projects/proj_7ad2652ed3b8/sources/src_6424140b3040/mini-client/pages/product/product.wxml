<view style="height:240px;background:#f5f5f5;display:flex;align-items:center;justify-content:center;font-size:64px">🍽</view>

<view class="mp-card" style="border-radius:0;margin:0">
  <view style="font-size:20px;font-weight:600">{{product.name}}</view>
  <view style="font-size:13px;color:rgba(0,0,0,0.45);margin:6px 0">{{product.desc}}</view>
  <view style="display:flex;align-items:center;gap:8px;margin-top:8px">
    <view style="color:#ff4d4f;font-size:24px;font-weight:600">¥{{product.price}}</view>
    <view style="color:rgba(0,0,0,0.25);text-decoration:line-through;font-size:13px" wx:if="{{product.origPrice}}">¥{{product.origPrice}}</view>
  </view>
</view>

<view class="mp-section-title">商品详情</view>
<view class="mp-card" style="min-height:200px">
  <view style="color:rgba(0,0,0,0.65);font-size:14px;line-height:1.8">{{product.detail || '暂无详情'}}</view>
</view>

<view style="position:fixed;bottom:0;left:0;right:0;background:#fff;border-top:1px solid #f0f0f0;padding:12px 16px;display:flex;gap:10px;align-items:center;z-index:10">
  <view style="flex:1;display:flex;align-items:center;gap:8px">
    <view bindtap="addToCart" class="mp-btn gray" style="flex:1;height:36px;font-size:14px">加入购物车</view>
    <view bindtap="buyNow" class="mp-btn primary" style="flex:1;height:36px;font-size:14px">立即购买</view>
  </view>
</view>
