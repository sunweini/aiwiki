<view class="mp-section-title">商户列表 · {{parkName}}</view>

<view wx:for="{{shops}}" wx:key="id" class="mp-card flush">
  <view style="display:flex;align-items:center;gap:10px">
    <view style="width:44px;height:44px;border-radius:8px;background:linear-gradient(135deg,#1677ff,#0958d9);color:#fff;display:flex;align-items:center;justify-content:center;font-size:18px">🏪</view>
    <view style="flex:1;min-width:0">
      <view style="font-size:15px;font-weight:500">{{item.name}}</view>
      <view style="font-size:12px;color:rgba(0,0,0,0.45);margin-top:2px">{{item.type ? item.type.name : ''}} · {{item.address || ''}}</view>
    </view>
    <view class="tag {{item.status === 1 ? 'success' : 'error'}}">{{item.status === 1 ? '营业中' : '已关闭'}}</view>
  </view>
  <view style="display:flex;gap:8px;margin-top:12px">
    <view class="mp-btn gray" style="flex:1;height:32px;font-size:13px" bindtap="viewSales" data-id="{{item.id}}">销售额</view>
    <view class="mp-btn gray" style="flex:1;height:32px;font-size:13px" bindtap="viewOrders" data-id="{{item.id}}">订单</view>
    <view class="mp-btn gray" style="flex:1;height:32px;font-size:13px" bindtap="switchTo" data-id="{{item.id}}">切换到此商户</view>
  </view>
</view>

<view wx:if="{{shops.length === 0}}" class="empty">暂无商户</view>
